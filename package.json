{
  "name": "openclaw-wiki",
  "version": "0.1.0",
  "description": "Wikipedia-style browser for OpenClaw agent memory",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c yellow,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch server/index.mjs",
    "dev:web": "vite --config web/vite.config.js",
    "build": "vite build --config web/vite.config.js",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "chokidar": "^4.0.1",
    "fastify": "^5.1.0",
    "gray-matter": "^4.0.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.0",
    "vite": "^6.0.1"
  }
}
